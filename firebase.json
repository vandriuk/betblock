{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase",
      ".git",
      ".gitignore",
      ".github",
      "*.md",
      "node_modules",
      ".claude"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
